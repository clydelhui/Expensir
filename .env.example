# Expensir deployment configuration (§14). Copy to .env for local dev.
# NOTE: keep comments on their own lines — an inline comment after an empty
# value (KEY=   # like this) is parsed as the value by python-dotenv.

# "webhook" (prod) or "poll" (local dev)
MODE=webhook

BOT_TOKEN=

# validated on every webhook request; required when MODE=webhook
TELEGRAM_WEBHOOK_SECRET=

# for setWebhook (prod)
PUBLIC_URL=

# Neon POOLED url in prod (advisory locks need Postgres)
DATABASE_URL=sqlite+aiosqlite:///./expensir.db

# telegram user id; runs /import, full /export, undo locked actions
OPERATOR_USER_ID=

# NL extractor (ADR-0010): any OpenAI-compatible endpoint. Leave all three
# blank to disable NL — slash commands still work. Local Ollama example:
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_API_KEY=ollama   (Ollama ignores it, but the value must be non-empty)
#   LLM_MODEL=llama3.1   (a model you've pulled; see `ollama list`)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# per-request timeout (seconds). Cloud providers answer in <30s; a local model
# on a cold load can take much longer — raise this (e.g. 300) for local dev.
LLM_TIMEOUT_SECONDS=30
